{
  "name": "rundossier",
  "version": "0.1.0",
  "description": "Local-first run evidence packets for agent and developer handoffs.",
  "type": "module",
  "bin": {
    "rundossier": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "evidence",
    "handoff",
    "local-first",
    "redaction",
    "git"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/rundossier.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/rundossier/issues"
  },
  "homepage": "https://github.com/rogerchappel/rundossier#readme"
}
